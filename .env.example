# Local PostgreSQL example:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/chartgosi

# Supabase examples:
# 1. Paste the URI from Supabase Project Settings > Database > Connection string.
# 2. Both postgresql:// and postgres:// are accepted; the backend converts them to asyncpg.
# 3. For Supabase pooler URLs, the backend automatically disables asyncpg statement cache.
# DATABASE_URL=postgresql://postgres.your-project-ref:YOUR_PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# Local frontend:
BACKEND_CORS_ORIGINS=http://localhost:3000

# Render production example:
# BACKEND_CORS_ORIGINS=http://localhost:3000,https://your-vercel-project.vercel.app

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Vercel production example:
# NEXT_PUBLIC_API_BASE_URL=https://chartgosi.onrender.com/api/v1
